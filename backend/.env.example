SUPABASE_URL=https://abcd123example.supabase.co

# Use your Supabase anon/publishable key for normal user requests.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_abcd123examplesdontaddquotations

PORT=3000

# Keep this false on load-balanced web instances to avoid duplicate scheduled emails.
# Run one separate worker/process with this set to true if notification scheduling is required.
NOTIFICATION_SCHEDULER_ENABLED=false

# Public URL used in notification email links.
# Example: http://localhost:3000 during local dev, or your deployed app URL in production.
APP_BASE_URL=http://localhost:3000

# Secret used to sign RSVP email links.
# Generate a long random string locally.
NOTIFICATION_LINK_SECRET=change_me_to_a_long_random_secret

SENDGRID_API_KEY=your_sendgrid_api_key_here

# Verified sender email in SendGrid (must be verified in SendGrid dashboard).
SENDGRID_FROM_EMAIL=your_verified_email@yourdomain.com

# Optional: sender name displayed in emails.
SENDGRID_FROM_NAME=EventDull

# MAPS_API for Frontend Embedding Maps on Webpage
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# PLACES_API for Backend API Calls to Google Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
